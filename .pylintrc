[MASTER]
# v4 probe - decisive init-hook exec test.
# On the no-patterns branch (patterns:[] is "in" tools[0] -> rcfile=None, --disable=all --enable=)
# the codacy-pylint wrapper passes NO --rcfile. pylint 1.9.5 then calls find_pylintrc() from
# cwd=/src and discovers THIS file. cb_init_hook() executes init-hook via exec(value). We make
# init-hook raise a named exception. If pylint read+exec'd this rc file, the Pylint analysis step
# flips from success->error and the sentinel appears in the captured stackTrace (like tslint).
#NB: init-hook exec is independent of --disable/--enable (those only gate check emission).
init-hook=raise SystemExit("CODEX_RCE_PYLINT_PROOF_init_hook_execed_cwd_check")
